# ==========================================================
# BACKEND API ENVIRONMENT VARIABLES (Django)
# ==========================================================

# Server
DEBUG=true
SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
# Use 8000 if you see "You don't have permission to access that port" on Windows (also set NEXT_PUBLIC_API_BASE_URL in apps/web/.env)
PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:8001,http://localhost:8000

# Database
DATABASE_URL=postgres://postgres:password@localhost:5432/turbo-template

# Optional: override DATABASE_URL with individual vars
# PGDATABASE=turbo_template
# PGUSER=postgres
# PGPASSWORD=password
# PGHOST=localhost
# PGPORT=5432
