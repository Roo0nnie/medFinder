# ==========================================================
# BACKEND API ENVIRONMENT VARIABLES
# ==========================================================

# ----------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------
NODE_ENV=development
# Server port (optional, defaults to 3000)
PORT=3000
# Base URL for the API server (optional, defaults to http://localhost:3000)
API_BASE_URL=http://localhost:3000
# API version string (required)
API_VERSION=v1

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
# PostgreSQL connection URL
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgres://postgres:password@localhost:5432/turbo-template"

# ----------------------------------------------------------
# Authentication (Better Auth)
# ----------------------------------------------------------
# The base URL for authentication endpoints
BETTER_AUTH_URL=http://localhost:3000
# Secret for Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=default-secret-for-testing-change-in-production
# Legacy fallback for Better Auth (use BETTER_AUTH_SECRET instead)
AUTH_SECRET=default-secret-for-testing-change-in-production

# ----------------------------------------------------------
# OAuth Providers (Google)
# ----------------------------------------------------------
# Google OAuth Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret
