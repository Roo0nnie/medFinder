{
	"$schema": "https://json.schemastore.org/nest-cli",
	"collection": "@nestjs/schematics",
	"sourceRoot": "src",
	"compilerOptions": {
		"deleteOutDir": false,
		"webpackConfigPath": false,
		"plugins": [
			{
				"name": "@nestjs/swagger",
				"options": {
					"dtoFileNameSuffix": [".dto.ts", ".schema.ts"],
					"dtoKeyOfComment": "description"
				}
			}
		]
	}
}
