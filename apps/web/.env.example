# ==========================================================
# WEB APP ENVIRONMENT VARIABLES
# ==========================================================

# ----------------------------------------------------------
# Server Configuration
# ----------------------------------------------------------
NODE_ENV=development

# ----------------------------------------------------------
# Public URLs
# ----------------------------------------------------------
# The base URL for web application (client-side accessible)
NEXT_PUBLIC_APP_URL=http://localhost:3001
# The base URL for API endpoint (client-side accessible)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ----------------------------------------------------------
# Authentication (Better Auth)
# ----------------------------------------------------------
# Public URL for authentication endpoints (client-side accessible)
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000/api/auth
# Secret for Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=default-secret-for-testing-change-in-production
# Comma-separated list of trusted origins for authentication
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3000
