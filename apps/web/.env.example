# ==========================================================
# WEB APP ENVIRONMENT VARIABLES
# ==========================================================

# Server Configuration
NODE_ENV=development

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:8001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
NEXT_PUBLIC_API_VERSION=v1

# Better Auth (used by /api/auth route; server-side)
BETTER_AUTH_BASE_PATH=/api/auth
BETTER_AUTH_SECRET=change-me-min-32-chars-long-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8001,http://localhost:8000
DATABASE_URL=postgres://postgres:password@localhost:5432/medFinder
