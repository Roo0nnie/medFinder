# Database Connection
DATABASE_URL="postgres://postgres:password@localhost:5432/turbo-template"

# Better Auth (required for pnpm dev:seed)
BETTER_AUTH_SECRET=change-me-min-32-chars-long-secret
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8001,http://localhost:8000
