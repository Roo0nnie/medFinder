{
	"family": "${PROJECT_NAME}-web",
	"networkMode": "awsvpc",
	"requiresCompatibilities": ["FARGATE"],
	"cpu": "512",
	"memory": "1024",
	"executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ecsTaskExecutionRole",
	"taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ecsTaskExecutionRole",
	"containerDefinitions": [
		{
			"name": "web",
			"image": "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${PROJECT_NAME}-web:${IMAGE_TAG:-latest}",
			"portMappings": [
				{
					"containerPort": 8001,
					"protocol": "tcp"
				}
			],
			"essential": true,
			"environment": [
				{
					"name": "NODE_ENV",
					"value": "production"
				},
				{
					"name": "NEXT_PUBLIC_APP_URL",
					"value": "${NEXT_PUBLIC_APP_URL}"
				},
				{
					"name": "NEXT_PUBLIC_API_BASE_URL",
					"value": "${NEXT_PUBLIC_API_BASE_URL}"
				},
				{
					"name": "NEXT_PUBLIC_API_VERSION",
					"value": "${NEXT_PUBLIC_API_VERSION}"
				}
			],
			"logConfiguration": {
				"logDriver": "awslogs",
				"options": {
					"awslogs-group": "/ecs/${PROJECT_NAME}-web",
					"awslogs-region": "${AWS_REGION}",
					"awslogs-stream-prefix": "ecs",
					"awslogs-create-group": "true"
				}
			},
			"healthCheck": {
				"command": [
					"CMD-SHELL",
					"wget --no-verbose --tries=1 --spider http://localhost:8001/ || exit 1"
				],
				"interval": 30,
				"timeout": 10,
				"retries": 3,
				"startPeriod": 40
			}
		}
	],
	"tags": [
		{
			"key": "Name",
			"value": "${PROJECT_NAME}-web"
		},
		{
			"key": "Environment",
			"value": "production"
		}
	]
}
