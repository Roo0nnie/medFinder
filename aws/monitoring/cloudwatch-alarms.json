{
	"webCpuAlarm": {
		"AlarmName": "${PROJECT_NAME}-web-cpu-high",
		"AlarmDescription": "Alert when web service CPU utilization exceeds 80%",
		"MetricName": "CPUUtilization",
		"Namespace": "AWS/ECS",
		"Statistic": "Average",
		"Period": 300,
		"EvaluationPeriods": 2,
		"Threshold": 80,
		"ComparisonOperator": "GreaterThanThreshold",
		"Dimensions": [
			{
				"Name": "ServiceName",
				"Value": "${PROJECT_NAME}-web-service"
			},
			{
				"Name": "ClusterName",
				"Value": "${PROJECT_NAME}-cluster"
			}
		],
		"AlarmActions": ["arn:aws:sns:${AWS_REGION}:${AWS_ACCOUNT_ID}:${PROJECT_NAME}-alerts"],
		"OKActions": ["arn:aws:sns:${AWS_REGION}:${AWS_ACCOUNT_ID}:${PROJECT_NAME}-alerts"],
		"InsufficientDataActions": []
	},
